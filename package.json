{
  "name": "projectos-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "pnpm format:check && pnpm lint && turbo build",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "docs:generate": "pnpm --filter server docs:generate",
    "docs:watch": "pnpm --filter server docs:watch"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2"
  }
}
